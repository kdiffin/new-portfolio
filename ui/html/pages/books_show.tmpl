{{define "title"}}{{.Data.Entry.Title}}{{end}}

{{define "main"}}
<article class="mb-8">
  <p class="text-muted text-left whitespace-nowrap tabular-nums max-[640px]:text-left light:text-muted-light">{{fmtDate .Data.Entry.PublishedAt}}</p>
  <h1 class="mb-2 text-base font-semibold leading-tight tracking-[.009em]">{{.Data.Entry.Title}}</h1>
  <div class="mt-4 text-base leading-[1.6] text-body light:text-body-light content-body">{{.Data.Entry.BodyHTML}}</div>
</article>
{{end}}